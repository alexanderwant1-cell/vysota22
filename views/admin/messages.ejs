<%- include('../partials/header') %>

<div class="container" style="padding: 2rem 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h2 style="font-weight: 500;">✉️ Сообщения от клиентов</h2>
        <a href="/admin/dashboard" style="color: var(--accent); text-decoration: none;">← Назад в панель</a>
    </div>
    
    <div class="card">
        <div class="card-header">
            <span>Все сообщения</span>
            <span style="float: right;">Всего: <%= messages.length %></span>
        </div>
        <div class="card-body">
            <% if (messages.length === 0) { %>
                <p style="text-align: center; color: var(--text-secondary); padding: 2rem;">📭 Нет сообщений</p>
            <% } else { %>
                <% messages.forEach(msg => { %>
                    <div style="border-bottom: 1px solid var(--border); padding: 1rem; margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; flex-wrap: wrap;">
                            <div>
                                <strong style="font-size: 1rem;"><%= msg.name %></strong>
                                <span style="color: var(--text-secondary); margin-left: 0.5rem;">&lt;<%= msg.email %>&gt;</span>
                            </div>
                            <div style="display: flex; gap: 1rem; align-items: center;">
                                <small style="color: var(--text-secondary);"><%= new Date(msg.createdAt).toLocaleString('ru-RU') %></small>
                                <a href="/admin/messages/delete/<%= msg.id %>" onclick="return confirm('Удалить сообщение?')" style="color: #dc2626; text-decoration: none;">🗑️</a>
                            </div>
                        </div>
                        <div style="margin-top: 0.75rem; padding: 0.5rem; background: var(--bg-primary); border-radius: 8px; line-height: 1.5;">
                            <%= msg.message.replace(/\n/g, '<br>') %>
                        </div>
                        <% if (!msg.is_read) { %>
                            <div style="margin-top: 0.5rem;">
                                <span style="font-size: 0.7rem; background: var(--accent); color: white; padding: 0.2rem 0.5rem; border-radius: 10px;">Новое</span>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>